# ============================================================
# Production RAG System — Environment Configuration
# ============================================================

# Required: Get your free token at https://huggingface.co/settings/tokens
HF_API_TOKEN=your-huggingface-token-here

# Models (optional — defaults shown)
HF_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Storage
CHROMA_PERSIST_DIR=./chroma_db
MONITORING_DB_PATH=./monitoring.db

# Cache
CACHE_MAX_SIZE=1000
CACHE_TTL=3600

# Retrieval
MAX_CONTEXT_TOKENS=3000
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5

# Rate Limiting
RATE_LIMIT_RPM=30

# Cost Tracking (USD per 1K tokens)
COST_PER_1K_EMBEDDING_TOKENS=0.0001
COST_PER_1K_GENERATION_TOKENS=0.0006
